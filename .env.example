# Copy this file to .env and fill in your values.
# python-dotenv will load it automatically when haminder.py starts.
#
# On macOS/Linux you can alternatively source env.sh in your shell.
# On Windows, set these here or via System Properties > Environment Variables.

HA_HOST=http://homeassistant.local:8123
HA_AUTH=your_long_lived_access_token_here
